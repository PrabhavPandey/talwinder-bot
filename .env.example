# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database (PostgreSQL)
# For local: postgresql://username:password@localhost:5432/talwinder_db
# For production (Railway): use the provided DATABASE_URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/talwinder_db

# Meta Cloud API (WhatsApp)
# Get from Facebook Developers Console
META_PHONE_NUMBER_ID=your_phone_number_id
META_ACCESS_TOKEN=your_permanent_access_token
META_VERIFY_TOKEN=your_chosen_verify_token
META_API_VERSION=v21.0

# Google Gemini AI
# Get from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key
AI_MODEL=gemini-1.5-pro

