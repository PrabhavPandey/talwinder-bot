{
  "name": "talwinder-bot",
  "version": "1.0.0",
  "description": "Talwinder - Grapevine's Idea Sponsorship Bot powered by Google Gemini AI",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "NODE_ENV=development nodemon src/app.js",
    "db:sync": "node -e 'require(\"./src/models\").sequelize.sync({ alter: true }).then(() => process.exit())'",
    "db:migrate": "node src/utils/migrate.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "chrono-node": "^2.7.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
